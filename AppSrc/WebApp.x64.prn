37846>>>    Procedure OnNavigateForward tWebNavigateData NavigateData Integer hoInvokingView Integer hoInvokingObject
37849>>>        WebSet pbRender of oNewButton to True
37850>>>        WebSet pbRender of oDetailButton to True
37851>>>
37851>>>        Case Begin
37851>>>            Case (NavigateData.eNavigateType = nfFromParent)
37853>>>                // If from parent, this is a constrained drill down
37853>>>                Case Break
37854>>>
37854>>>            Case (NavigateData.eNavigateType = nfFromChild)
37857>>>                // If from child, this is a probably a parent lookup from a Zoom
37857>>>                Case Break
37858>>>
37858>>>            Case (NavigateData.eNavigateType = nfFromMain)
37861>>>                // If from main, this is a probably a main-file lookup from a Zoom
37861>>>                WebSet pbRender of oDetailButton to False
37862>>>                Case Break
37863>>>
37863>>>            Case Else // must be nfUndefined
37863>>>                // This may be the start of a drilldown query or this may be used for some kind of custom query.
37863>>>
37863>>>        Case End
37863>>>
37863>>>    End_Procedure
37864>>>
37864>>>
37864>>>End_Object 
